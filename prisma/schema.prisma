generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model Note {
  id        String   @id @default(cuid())
  content   String
  summary   String?
  embedding Float[]
  tags      String[]
  category  String?
  createdAt DateTime @default(now())
}

model Connection {
  id         String @id @default(cuid())
  fromId     String
  toId       String
  strength   Float
}